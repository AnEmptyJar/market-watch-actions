

def _rtt_status(v):
    try:
        if v is None:
            return "FAIL"
        v=float(v)
        if v<=800:
            return "OK"
        if v<=2000:
            return "SLOW"
        return "BAD"
    except:
        return "FAIL"

ALERT_COOLDOWN = 600
#!/usr/bin/env python3
import os, json, time, ssl, socket
import urllib.request
from urllib.error import HTTPError
from typing import Optional
from pathlib import Path

# --- compat stub: avoid crash if legacy calls remain ---
def check_tg_status(*_a, **_kw):
    return
# --- end stub ---


BASE_DIR = os.path.expanduser("~/LAB/MONITOR_SYSTEM/monitor_system")
CONFIG_PATH = os.path.join(BASE_DIR, "config", "config.json")
STATE_FILE  = os.path.join(BASE_DIR, "state", "network_state.json")
LOG_FILE    = os.path.join(BASE_DIR, "logs", "network_watch.log")
ERR_FILE    = os.path.join(BASE_DIR, "logs", "network_watch.err")

def ensure_dirs():
    os.makedirs(os.path.join(BASE_DIR, "logs"), exist_ok=True)
    os.makedirs(os.path.join(BASE_DIR, "state"), exist_ok=True)
    os.makedirs(os.path.join(BASE_DIR, "config"), exist_ok=True)

def classify_incident(issues, tcp_ok, reality_ok, google_ok, youtube_ok, pub_ip, expected_exit_ip):
    issues = issues or []
    joined = " ".join(issues)

    # 优先级：先判断“最确定”的场景
    if "TCP_FAIL" in issues:
        return "VPS_PORT_BLOCK_OR_DOWN"  # 端口被封 / VPS不可达 / 服务器挂

    if "CLAUDE_LINK_FAIL" in joined:
        return "CLAUDE_LINK_FAIL"        # Claude 专线异常（US住宅出口异常/不可达）
    if "OPENAI_LINK_FAIL" in joined:
        return "OPENAI_LINK_FAIL"        # OpenAI 专线异常（JP VPS链路异常）

    if ("REALITY_FAIL" in issues) and tcp_ok:
        # TCP通但Reality失败：很像协议/握手层被干扰
        if (not google_ok) or (not youtube_ok):
            return "GFW_INTERFERENCE_REALITY"  # Reality被干扰 + 外网失败
        return "REALITY_HANDSHAKE_ISSUE"       # 仅Reality探测失败

    if ("GOOGLE_FAIL" in issues or "YOUTUBE_FAIL" in issues) and tcp_ok:
        return "PARTIAL_BLOCK_OR_DNS_TLS_ISSUE" # 局部失败（DNS/证书/策略/分流）

    if ("LATENCY_UNKNOWN" in joined) and ("REALITY_LAT_UNKNOWN" in joined):
        return "PACKET_LOSS_OR_TIMEOUT"

    if ("REALITY_LATENCY_HIGH" in joined) or ("LATENCY_HIGH" in joined):
        return "NETWORK_CONGESTION_OR_QOS"      # 拥塞/抖动/运营商QOS/线路波动

    return "UNKNOWN"


def log(msg: str):
    ts = time.strftime("%Y-%m-%d %H:%M:%S")
    line = f"[{ts}] {msg}"
    with open(LOG_FILE, "a", encoding="utf-8") as f:
        f.write(line + "\n")
    print(line)

def load_json(path: str, default: dict) -> dict:
    try:
        with open(path, "r", encoding="utf-8") as f:
            return json.load(f)
    except Exception:
        return default

def save_json(path: str, obj: dict):
    tmp = path + ".tmp"
    with open(tmp, "w", encoding="utf-8") as f:
        json.dump(obj, f, ensure_ascii=False, indent=2)
    os.replace(tmp, path)

def http_get_text(url: str, timeout: int) -> str:
    req = urllib.request.Request(url, headers={"User-Agent":"monitor_system/network_watch_pro"})
    ctx = ssl.create_default_context()
    with urllib.request.urlopen(req, timeout=timeout, context=ctx) as r:
        return r.read().decode("utf-8", errors="ignore")

def tcp_probe(host: str, port: int, timeout: int) -> bool:
    try:
        with socket.create_connection((host, port), timeout=timeout):
            return True
    except Exception:
        return False


def dns_probe(hostname: str, timeout: int = 5) -> bool:
    try:
        old_to = socket.getdefaulttimeout()
        socket.setdefaulttimeout(timeout)
        socket.gethostbyname(hostname)
        socket.setdefaulttimeout(old_to)
        return True
    except Exception:
        try:
            socket.setdefaulttimeout(None)
        except Exception:
            pass
        return False

def latency_probe_ms(host: str, port: int, timeout: int) -> Optional[int]:
    t0 = time.time()
    try:
        with socket.create_connection((host, port), timeout=timeout):
            pass
        return int((time.time() - t0) * 1000)
    except Exception:
        return None

def public_ip_probe(timeout: int) -> Optional[str]:
    # ipinfo 偶尔会抽风（你见过 WRONG_VERSION_NUMBER），这里做多源兜底
    urls = [
        "https://ipinfo.io/ip",
        "https://api.ipify.org",
        "https://ifconfig.me/ip",
    ]
    last = None
    for u in urls:
        try:
            ip = http_get_text(u, timeout).strip()
            if ip and 7 <= len(ip) <= 64:
                return ip
        except Exception as e:
            last = e
            continue
    if last:
        log(f"[WARN] public_ip_probe fail - {last}")
    return None

def google_probe(timeout: int) -> bool:
    try:
        # 204 代表通
        req = urllib.request.Request("https://www.google.com/generate_204",
                                     headers={"User-Agent":"monitor_system/google_probe"})
        with urllib.request.urlopen(req, timeout=timeout, context=ssl.create_default_context()) as r:
            return int(getattr(r, "status", 0)) in (204, 200)
    except Exception:
        return False

def reality_probe(timeout: int) -> bool:
    # 你 Reality dest 是 www.cloudflare.com，所以用 cf trace 做“链路可用”探针
    try:
        t = http_get_text("https://www.cloudflare.com/cdn-cgi/trace", timeout)
        return ("ip=" in t) and ("loc=" in t)
    except Exception:
        return False

def openai_trace_probe(timeout: int) -> dict:
    try:
        t = http_get_text("https://chat.openai.com/cdn-cgi/trace", timeout)
        d = {}
        for line in t.splitlines():
            if "=" in line:
                k, v = line.split("=", 1)
                d[k.strip()] = v.strip()
        return d
    except Exception:
        return {}





def gpt_rtt_probe(timeout: int) -> Optional[int]:
    import time, ssl, urllib.request
    try:
        req = urllib.request.Request(
            "https://chat.openai.com/cdn-cgi/trace",
            headers={"User-Agent": "monitor_system/gpt_rtt"}
        )
        ctx = ssl.create_default_context()
        t0 = time.perf_counter()
        with urllib.request.urlopen(req, timeout=timeout, context=ctx) as r:
            _ = r.read(128)
        t1 = time.perf_counter()
        return int((t1 - t0) * 1000)
    except Exception:
        return None


def claude_rtt_probe(timeout: int) -> Optional[int]:
    import time, ssl, urllib.request
    try:
        req = urllib.request.Request(
            "https://claude.ai/cdn-cgi/trace",
            headers={"User-Agent": "monitor_system/claude_rtt"}
        )
        ctx = ssl.create_default_context()
        t0 = time.perf_counter()
        with urllib.request.urlopen(req, timeout=timeout, context=ctx) as r:
            _ = r.read(128)
        t1 = time.perf_counter()
        return int((t1 - t0) * 1000)
    except Exception:
        return None


def claude_trace_probe(timeout: int) -> dict:
    try:
        t = http_get_text("https://claude.ai/cdn-cgi/trace", timeout)
        d = {}
        for line in t.splitlines():
            if "=" in line:
                k, v = line.split("=", 1)
                d[k.strip()] = v.strip()
        return d
    except Exception:
        return {}

def youtube_probe(timeout: int) -> bool:
    # 轻量探针：能拿到 report_mapping 即认为 YouTube CDN 访问正常
    try:
        t = http_get_text("https://redirector.googlevideo.com/report_mapping", timeout)
        return ("GoogleVideo" in t) or ("report" in t) or (len(t) > 20)
    except Exception:
        return False

def tg_send(text: str, cfg: dict) -> bool:
    token = cfg["telegram"]["bot_token"].strip()
    chat_id = str(cfg["telegram"]["chat_id"]).strip()
    url = f"https://api.telegram.org/bot{token}/sendMessage"
    data = json.dumps({
        "chat_id": chat_id,
        "text": text,
        "disable_web_page_preview": True
    }).encode("utf-8")
    req = urllib.request.Request(url, data=data, headers={"Content-Type":"application/json"})
    ctx = ssl.create_default_context()
    with urllib.request.urlopen(req, timeout=10, context=ctx) as r:
        _ = r.read()
    return True

def tg_send_safe(text: str, cfg: dict, st: dict) -> bool:
    now_ts = int(time.time())
    cooldown_sec = int(cfg.get("telegram", {}).get("cooldown_sec", 600))
    tg = st.setdefault("telegram", {})
    last_fail = int(tg.get("last_fail_ts", 0) or 0)
    if last_fail and (now_ts - last_fail) < cooldown_sec:
        log(f"[WARN] telegram cooldown active ({now_ts-last_fail}s<{cooldown_sec}s), skip send")
        tg["outbox_text"] = text
        tg["outbox_ts"] = now_ts
        return False

    # 先尝试发送 outbox
    if tg.get("outbox_text"):
        try:
            tg_send(tg["outbox_text"], cfg)
            tg.pop("outbox_text", None)
            tg.pop("outbox_ts", None)
            tg.pop("last_fail_ts", None)
            log("[INFO] telegram outbox delivered")
        except Exception as e:
            tg["last_fail_ts"] = now_ts
            log(f"[WARN] telegram send failed (outbox): {e}")
            return False

    try:
        tg_send(text, cfg)
        tg.pop("last_fail_ts", None)
        return True
    except Exception as e:
        tg["last_fail_ts"] = now_ts
        tg["outbox_text"] = text
        tg["outbox_ts"] = now_ts
        log(f"[WARN] telegram send failed: {e}")
        return False

def can_alert(st: dict, key: str, now_ts: int, cooldown: int) -> bool:
    ts = st.setdefault("alert_ts", {})
    last = int(ts.get(key, 0) or 0)
    return (now_ts - last) >= cooldown

def mark_alert(st: dict, key: str, now_ts: int):
    st.setdefault("alert_ts", {})[key] = now_ts

def mask_ip(ip: Optional[str]) -> str:
    if not ip:
        return "null"
    parts = ip.split(".")
    if len(parts) == 4:
        return f"{parts[0]}.{parts[1]}.xx.xx"
    return ip[:6] + "…"


def reality_http_latency_ms(timeout: int) -> Optional[int]:
    """
    Real-world latency: do a small HTTPS request to Cloudflare trace endpoint.
    Returns elapsed ms, or None on failure.
    """
    try:
        import urllib.request, ssl, time as _t
        url = "https://www.cloudflare.com/cdn-cgi/trace"
        req = urllib.request.Request(url, headers={"User-Agent":"monitor_system/1.0"})
        ctx = ssl.create_default_context()
        t0 = _t.perf_counter()
        with urllib.request.urlopen(req, timeout=timeout, context=ctx) as r:
            _ = r.read(256)
        t1 = _t.perf_counter()
        return int((t1 - t0) * 1000)
    except Exception:
        return None

def main():
    ensure_dirs()
    cfg = load_json(CONFIG_PATH, {})
    st  = load_json(STATE_FILE, {})

    net = cfg.get("network", {})
    vps_host = str(net.get("vps_host", "")).strip()
    vps_port = int(net.get("vps_port", 0) or 0)
    expected_exit_ip = str(net.get("expected_exit_ip", "")).strip()

    if not vps_host or not vps_port or not expected_exit_ip:
        log("[ERROR] config.network missing vps_host/vps_port/expected_exit_ip")
        return

    timeout = int(net.get("timeout_sec", 8) or 8)
    now_ts = int(time.time())

    issues = []
    tcp_ok = tcp_probe(vps_host, vps_port, timeout)
    st["tcp_ok"] = bool(tcp_ok)

    pub_ip = public_ip_probe(timeout)
    st["public_ip"] = pub_ip

    google_ok = google_probe(timeout)
    st["google_ok"] = bool(google_ok)

    dns_google_ok = dns_probe("google.com", timeout)
    dns_youtube_ok = dns_probe("youtube.com", timeout)
    dns_ok = bool(dns_google_ok and dns_youtube_ok)
    st["dns_ok"] = dns_ok
    st["dns_detail"] = {
        "google.com": bool(dns_google_ok),
        "youtube.com": bool(dns_youtube_ok),
    }

    reality_ok = reality_probe(timeout)
    st["reality_ok"] = bool(reality_ok)

    openai_trace = openai_trace_probe(timeout)
    st["openai_trace"] = openai_trace
    openai_ok = (openai_trace.get("loc") == "JP")
    st["openai_ok"] = bool(openai_ok)

    gpt_rtt_ms = gpt_rtt_probe(timeout)
    st["gpt_rtt_ms"] = gpt_rtt_ms

    claude_trace = claude_trace_probe(timeout)

    claude_rtt_ms = claude_rtt_probe(timeout)
    st["claude_rtt_ms"] = claude_rtt_ms
    
    level = "GOOD"
    if claude_rtt_ms is None:
        level = "UNKNOWN"
    elif claude_rtt_ms > 2000:
        level = "BAD"
    elif claude_rtt_ms > 1200:
        level = "SLOW"
    elif claude_rtt_ms > 600:
        level = "NORMAL"

    log(f"[RTT] claude_rtt_ms={claude_rtt_ms} level={level}")



    st["claude_trace"] = claude_trace
    claude_ok = (claude_trace.get("loc") == "US")
    st["claude_ok"] = bool(claude_ok)

    youtube_ok = youtube_probe(timeout)
    st["youtube_ok"] = bool(youtube_ok)

    port_ms = latency_probe_ms(vps_host, vps_port, timeout)

    reality_lat_ms = reality_http_latency_ms(timeout)
    st["port_ms"] = int(port_ms) if isinstance(port_ms, int) else None
    st["vps_rtt_ms"] = int(port_ms) if isinstance(port_ms, int) else None
    st["reality_lat_ms"] = int(reality_lat_ms) if isinstance(reality_lat_ms, int) else None
    st["reality_rtt_ms"] = int(reality_lat_ms) if isinstance(reality_lat_ms, int) else None

    # 规则：出错项 -> issues
    if not tcp_ok:
        issues.append("TCP_FAIL")
    if (pub_ip is None):
        issues.append("EXIT_IP_UNKNOWN")

    if not reality_ok:
        issues.append("REALITY_FAIL")

    # AI 链路使用 2-strike，降低瞬时抖动误报
    if not openai_ok:
        st["openai_link_fail_count"] = int(st.get("openai_link_fail_count", 0) or 0) + 1
    else:
        st["openai_link_fail_count"] = 0

    if not claude_ok:
        st["claude_link_fail_count"] = int(st.get("claude_link_fail_count", 0) or 0) + 1
    else:
        st["claude_link_fail_count"] = 0

    if int(st.get("openai_link_fail_count", 0) or 0) >= 2:
        issues.append(f"OPENAI_LINK_FAIL loc={openai_trace.get('loc','?')} ip={openai_trace.get('ip','?')}")

    if int(st.get("claude_link_fail_count", 0) or 0) >= 2:
        issues.append(f"CLAUDE_LINK_FAIL loc={claude_trace.get('loc','?')} ip={claude_trace.get('ip','?')}")

    # DNS / Google / YouTube 使用 2-strike，降低瞬时抖动误报
    if not dns_google_ok:
        st["dns_google_fail_count"] = int(st.get("dns_google_fail_count", 0) or 0) + 1
    else:
        st["dns_google_fail_count"] = 0

    if not dns_youtube_ok:
        st["dns_youtube_fail_count"] = int(st.get("dns_youtube_fail_count", 0) or 0) + 1
    else:
        st["dns_youtube_fail_count"] = 0

    if not google_ok:
        st["google_fail_count"] = int(st.get("google_fail_count", 0) or 0) + 1
    else:
        st["google_fail_count"] = 0

    if not youtube_ok:
        st["youtube_fail_count"] = int(st.get("youtube_fail_count", 0) or 0) + 1
    else:
        st["youtube_fail_count"] = 0

    if int(st.get("dns_google_fail_count", 0) or 0) >= 2:
        issues.append("DNS_FAIL google.com")
    if int(st.get("dns_youtube_fail_count", 0) or 0) >= 2:
        issues.append("DNS_FAIL youtube.com")
    if int(st.get("google_fail_count", 0) or 0) >= 2:
        issues.append("GOOGLE_FAIL")
    if int(st.get("youtube_fail_count", 0) or 0) >= 2:
        issues.append("YOUTUBE_FAIL")
    # Reality latency missing once is noisy; record via state/log path, do not alert immediately
    if (reality_lat_ms is None):
        st["reality_lat_unknown_count"] = int(st.get("reality_lat_unknown_count", 0) or 0) + 1
    else:
        st["reality_lat_unknown_count"] = 0
        if reality_lat_ms >= 2000:
            issues.append(f"REALITY_LATENCY_HIGH {reality_lat_ms}ms")
    if (port_ms is None):
        issues.append("LATENCY_UNKNOWN")
    elif port_ms >= 200:
        issues.append(f"LATENCY_HIGH {port_ms}ms")

    # persist latest diagnostic snapshot for TG "net" command
    st["last_diag"] = {
        "issues": issues[:] if issues else [],
        "tcp_ok": bool(tcp_ok),
        "reality_ok": bool(reality_ok),
        "google_ok": bool(google_ok),
        "youtube_ok": bool(youtube_ok),
        "dns_ok": bool(dns_ok),
        "pub_ip": pub_ip,
        "public_ip": pub_ip,
        "expected_exit_ip": expected_exit_ip,
        "port_ms": int(port_ms) if isinstance(port_ms, int) else None,
        "vps_rtt_ms": int(port_ms) if isinstance(port_ms, int) else None,
        "reality_lat_ms": int(reality_lat_ms) if isinstance(reality_lat_ms, int) else None,
        "reality_rtt_ms": int(reality_lat_ms) if isinstance(reality_lat_ms, int) else None,
        "openai_ok": bool(openai_ok),
        "claude_ok": bool(claude_ok),
        "openai_trace": openai_trace,
        "claude_trace": claude_trace,
        "gpt_rtt_ms": int(gpt_rtt_ms) if isinstance(gpt_rtt_ms, int) else None,
        "claude_rtt_ms": int(claude_rtt_ms) if isinstance(claude_rtt_ms, int) else None,
        "ts": now_ts,
    }


    # 告警策略：同一 incident 做 cooldown，避免重复刷屏
    if issues:
        base_key = "net_fail"
        incident = classify_incident(
            issues=issues,
            tcp_ok=tcp_ok,
            reality_ok=reality_ok,
            google_ok=google_ok,
            youtube_ok=youtube_ok,
            pub_ip=pub_ip,
            expected_exit_ip=expected_exit_ip,
        )
        final_key = f"{base_key}.{incident}" if incident else base_key

        # 默认 10 分钟冷却；未知类问题给更长冷却
        cooldown = ALERT_COOLDOWN
        if "EXIT_IP_UNKNOWN" in issues or "LATENCY_UNKNOWN" in issues:
            cooldown = max(ALERT_COOLDOWN, 1800)

        if can_alert(st, final_key, now_ts, cooldown):
            ip_show = (pub_ip.strip() if isinstance(pub_ip, str) else 'null')
            if ip_show.count('.') == 3:
                a,b,_,_ = ip_show.split('.')
                ip_show = f"{a}.{b}.xx.xx"
            port_show = (str(port_ms) + 'ms') if isinstance(port_ms, int) else 'null'
            rlat_show = (str(reality_lat_ms) + 'ms') if isinstance(reality_lat_ms, int) else 'null'
            issue_text = "；".join([_issue_text_cn(x) for x in issues[:6]]) if issues else "无"
            fs = int(st.get("fail_streak", 0) or 0)

            def okfmt(v):
                if v is True:
                    return "OK"
                if v is False:
                    return "FAIL"
                return "?"

            openai_loc = openai_trace.get("loc", "?")
            openai_ip = openai_trace.get("ip", "?")
            claude_loc = claude_trace.get("loc", "?")
            claude_ip = claude_trace.get("ip", "?")

            msg = (
                f'类型: {_incident_type_cn(incident)}\n'
                f'默认出口IP: {ip_show}\n'
                f'OpenAI: {okfmt(openai_ok)} ({openai_loc} / {openai_ip})\n'
                f'Claude: {okfmt(claude_ok)} ({claude_loc} / {claude_ip})\n'
                f'Claude RTT: {st.get("claude_rtt_ms","?")}ms\n'
                f'端口: {port_show} / Reality: {rlat_show}\n'
                f"Google: {okfmt(google_ok)} / YouTube: {okfmt(youtube_ok)} / DNS: {okfmt(st.get('dns_ok', None))}\n"
                f'问题: {issue_text}\n'
                f'连续: {fs}\n'
                f"@{time.strftime('%H:%M')}"
            )
            ok = tg_send_safe(msg, cfg, st)
            if ok:
                try:
                    log(f"[DIAG] snapshot issues={issues} tcp_ok={tcp_ok} reality_ok={reality_ok} google_ok={google_ok} youtube_ok={youtube_ok} pub_ip={pub_ip} expected_exit_ip={expected_exit_ip} port_ms={port_ms} reality_lat_ms={reality_lat_ms}")
                except Exception as _e:
                    log(f"[DIAG] snapshot failed: {_e}")

                log(f"[WARN] alert sent: {final_key}")
                mark_alert(st, final_key, now_ts)
            else:
                log(f"[WARN] alert NOT delivered (queued): {final_key}")
        else:
            log(f"[INFO] alert suppressed by cooldown: {final_key}")
    else:
        log("[INFO] healthy")
        _maybe_send_health_summary(
            cfg, st, now_ts,
            pub_ip, expected_exit_ip, port_ms, reality_lat_ms,
            google_ok, youtube_ok,
            openai_ok, claude_ok, openai_trace, claude_trace
        )

    _tg_poll_status_commands_v4(cfg, st)
    log(f"[STATE_DEBUG] gpt_rtt_ms={st.get('gpt_rtt_ms')} claude_rtt_ms={st.get('claude_rtt_ms')} vps_rtt_ms={st.get('vps_rtt_ms')} reality_rtt_ms={st.get('reality_rtt_ms')}")
    save_json(STATE_FILE, st)

# === Telegram command polling (status) - stdlib only ===
def _tg_api_call(token, method, params=None, timeout=10):
    try:
        import urllib.parse, urllib.request
        params = params or {}
        data = urllib.parse.urlencode(params).encode("utf-8")
        url = f"https://api.telegram.org/bot{token}/{method}"
        req = urllib.request.Request(url, data=data, method="POST")
        with urllib.request.urlopen(req, timeout=timeout) as r:
            return json.loads(r.read().decode("utf-8", errors="ignore"))
    except Exception as _e:
        try:
            log(f"[WARN] tg api failed: {method} err={_e}")
        except Exception:
            pass
        return None

def _tg_send_text(token, chat_id, text):
    return _tg_api_call(token, "sendMessage", {"chat_id": str(chat_id), "text": text})


def _maybe_send_health_summary(cfg: dict, st: dict, now_ts: int, pub_ip, expected_exit_ip, port_ms, reality_lat_ms, google_ok, youtube_ok, openai_ok=None, claude_ok=None, openai_trace=None, claude_trace=None) -> None:
    try:
        tg = (cfg or {}).get("telegram") or {}
        token = tg.get("bot_token")
        chat_id = tg.get("chat_id")
        if not token or not chat_id:
            log("[HEALTH] skip: missing telegram.bot_token or telegram.chat_id in config")
            return

        interval = int((((cfg or {}).get("network") or {}).get("summary_interval_sec", 1800)) or 1800)
        key = "network_health_summary"

        if not can_alert(st, key, now_ts, interval):
            return

        def okfmt(v):
            if v is True:
                return "OK"
            if v is False:
                return "FAIL"
            return "?"

        ip_show = pub_ip if isinstance(pub_ip, str) and pub_ip else "?"
        port_show = f"{port_ms}ms" if isinstance(port_ms, int) else "?"
        rlat_show = f"{reality_lat_ms}ms" if isinstance(reality_lat_ms, int) else "?"
        openai_trace = openai_trace or {}
        claude_trace = claude_trace or {}

        msg = (
            f"默认出口IP: {ip_show}\n"
            f"OpenAI: {okfmt(openai_ok)} ({openai_trace.get('loc','?')} / {openai_trace.get('ip','?')})\n"
            f"Claude: {okfmt(claude_ok)} ({claude_trace.get('loc','?')} / {claude_trace.get('ip','?')})\n"
            f"端口: {port_show} / Reality: {rlat_show}\n"
            f"Google: {okfmt(google_ok)} / YouTube: {okfmt(youtube_ok)} / DNS: {okfmt(st.get('dns_ok', None))}\n"
            f"问题: 无\n"
            f"@{time.strftime('%H:%M')}"
        )

        ok = tg_send_safe(msg, cfg, st)
        log(f"[HEALTH] sendMessage_ok={ok}")
        if ok:
            mark_alert(st, key, now_ts)
    except Exception as e:
        try:
            log(f"[HEALTH] exception: {e}")
        except Exception:
            pass

def _tg_poll_status_commands(cfg, st, status_text):
    """
    Poll Telegram updates and respond to 'status' or '/status'.
    Uses st['tg_last_update_id'] to avoid re-processing old messages.
    Only accepts messages from cfg telegram chat_id (same one you push alerts to).
    """
    try:
        tg = (cfg or {}).get("telegram") or {}
        token = tg.get("bot_token") or tg.get("token")
        chat_id = tg.get("chat_id")
        if not token or not chat_id:
            return

        last_id = int((st or {}).get("tg_last_update_id") or 0)
        offset = last_id + 1 if last_id else None

        params = {"timeout": "0"}
        if offset is not None:
            params["offset"] = str(offset)

        resp = _tg_api_call(token, "getUpdates", params)
        if not resp or not resp.get("ok"):
            return

        max_update_id = last_id
        for upd in resp.get("result", []):
            uid = int(upd.get("update_id", 0))
            max_update_id = max(max_update_id, uid)

            msg = upd.get("message") or upd.get("edited_message") or {}
            from_chat = (msg.get("chat") or {}).get("id")
            text = (msg.get("text") or "").strip().lower()

            # Only trust the same chat you configured for alerts
            if str(from_chat) != str(chat_id):
                continue

            if text in ("status", "/status"):
                _tg_send_text(token, chat_id, status_text)

        if max_update_id != last_id:
            st["tg_last_update_id"] = max_update_id

    except Exception as _e:
        try:
            log(f"[WARN] tg command poll failed: {_e}")
        except Exception:
            pass
# === end Telegram command polling ===





def _tg_poll_status_commands_v3(cfg, st):
    # Telegram status command: supports "status" or "/status"
    # Persist offset in st["tg_last_update_id"]
    try:
        import json, time, urllib.request, urllib.parse

        token = cfg.get("tg_bot_token") or cfg.get("telegram_bot_token") or cfg.get("bot_token")
        chat_id = cfg.get("tg_chat_id") or cfg.get("telegram_chat_id") or cfg.get("chat_id")
        if not token or not chat_id:
            return

        last_id = int(st.get("tg_last_update_id") or 0)

        params = {"timeout": 0}
        if last_id:
            params["offset"] = last_id + 1

        url = f"https://api.telegram.org/bot{token}/getUpdates?" + urllib.parse.urlencode(params)
        with urllib.request.urlopen(url, timeout=8) as r:
            data = json.loads(r.read().decode("utf-8"))

        if not data.get("ok"):
            return

        updates = data.get("result") or []
        max_id = last_id

        for u in updates:
            uid = u.get("update_id", 0)
            if uid > max_id:
                max_id = uid

            msg = u.get("message") or {}
            text = (msg.get("text") or "").strip()
            from_chat = (msg.get("chat") or {}).get("id")
            if str(from_chat) != str(chat_id):
                continue

            if text in ("status", "/status"):
                pub_ip = st.get("last_pub_ip") or st.get("pub_ip") or "NA"
                exp_ip = cfg.get("expected_exit_ip") or "NA"
                port_ms = st.get("last_port_ms") or st.get("port_ms") or "NA"
                rlat = st.get("last_reality_lat_ms") or st.get("reality_lat_ms") or "NA"
                issues = st.get("last_issues") or st.get("issues") or []
                if isinstance(issues, str):
                    issues = [issues]
                if not isinstance(issues, list):
                    issues = [str(issues)]

                lines = []
                lines.append("【network_watch 状态】")
                lines.append(f"ExitIP: {pub_ip} (expect {exp_ip})")
                lines.append(f"Port: {port_ms}ms | RealityLat: {rlat}ms")
                if issues:
                    lines.append("Issues:")
                    for x in issues[:8]:
                        lines.append(f"- {x}")
                else:
                    lines.append("Issues: (none)")
                lines.append("@" + time.strftime("%H:%M"))

                text_out = "\n".join(lines)
                send_url = f"https://api.telegram.org/bot{token}/sendMessage"
                body = urllib.parse.urlencode({"chat_id": chat_id, "text": text_out}).encode("utf-8")
                req = urllib.request.Request(send_url, data=body, method="POST")
                urllib.request.urlopen(req, timeout=8).read()

        if max_id > last_id:
            st["tg_last_update_id"] = max_id

    except Exception:
        return





def _queue_status_outbox(st: dict, reply: str):
    tg = st.setdefault("telegram", {})
    tg["status_outbox_text"] = reply
    tg["status_outbox_ts"] = int(time.time())

def _flush_status_outbox_v4(call, st: dict):
    tg = st.setdefault("telegram", {})
    txt = tg.get("status_outbox_text")
    if not txt:
        return True
    try:
        send_raw = call("sendMessage", {"chat_id": st.get("_tg_chat_id_for_status",""), "text": txt}, timeout=10)
        send_ok = '"ok":true' in send_raw
        if send_ok:
            tg.pop("status_outbox_text", None)
            tg.pop("status_outbox_ts", None)
            log("[TG_STATUS] queued status reply delivered")
            return True
        log(f"[TG_API_FAIL] queued status reply sendMessage not ok: {send_raw[:160]}")
        return False
    except Exception as e:
        log(f"[TG_API_FAIL] queued status reply failed: {e}")
        return False

# === TG_STATUS_V4_BEGIN ===

def _incident_type_cn(x):
    m = {
        "NETWORK_CONGESTION_OR_QOS": "网络拥塞 / QoS限速",
        "PARTIAL_BLOCK_OR_DNS_TLS_ISSUE": "部分访问异常 / DNS或TLS问题",
        "REALITY_HANDSHAKE_ISSUE": "Reality握手异常",
        "REALITY_FAIL": "Reality连接失败",
        "GFW_INTERFERENCE_REALITY": "GFW干扰 / Reality异常",
        "VPS_PORT_BLOCK_OR_DOWN": "VPS端口被封 / 服务器不可达",
        "PACKET_LOSS_OR_TIMEOUT": "丢包 / 请求超时",
        "CLAUDE_LINK_FAIL": "Claude链路异常",
        "OPENAI_LINK_FAIL": "OpenAI链路异常",
        "UNKNOWN": "未知异常",
        "EXIT_IP_MISMATCH": "出口IP异常",
        "EXIT_IP_UNKNOWN": "出口IP未知",
        "YOUTUBE_FAIL": "YouTube访问异常",
        "LATENCY_HIGH": "端口延迟过高",
        "LATENCY_UNKNOWN": "端口延迟未知",
        "REALITY_LATENCY_HIGH": "Reality延迟过高",
        "REALITY_LAT_UNKNOWN": "Reality延迟未知",
        "GOOGLE_FAIL": "Google访问异常",
        "DNS_FAIL": "DNS解析失败",
    }
    return m.get(str(x), str(x))

def _issue_text_cn(x):
    if x is None:
        return "无"
    t = str(x)

    # 先处理带参数的前缀
    if t.startswith("DNS_FAIL google.com"):
        return t.replace("DNS_FAIL google.com", "DNS解析失败 google.com", 1)
    if t.startswith("DNS_FAIL youtube.com"):
        return t.replace("DNS_FAIL youtube.com", "DNS解析失败 youtube.com", 1)
    if t.startswith("SSH_INVALID_USER_RECENT_HIGH:"):
        return t.replace("SSH_INVALID_USER_RECENT_HIGH:", "SSH无效用户扫描过多:", 1)
    if t.startswith("SSH_FAIL_RECENT_HIGH:"):
        return t.replace("SSH登录失败次数过多:", "SSH登录失败次数过多:", 1).replace("SSH_FAIL_RECENT_HIGH:", "SSH登录失败次数过多:", 1)
    if t.startswith("SYSTEMD_INACTIVE "):
        return t.replace("SYSTEMD_INACTIVE ", "服务未激活 ", 1)
    if t.startswith("CPU_HIGH "):
        return t.replace("CPU_HIGH ", "CPU过高 ", 1)
    if t.startswith("MEM_HIGH "):
        return t.replace("MEM_HIGH ", "内存占用过高 ", 1)
    if t.startswith("DISK_HIGH "):
        return t.replace("DISK_HIGH ", "磁盘占用过高 ", 1)
    if t.startswith("LOAD_HIGH "):
        return t.replace("LOAD_HIGH ", "系统负载过高 ", 1)

    # 再处理固定关键字
    mapping = {
        "NETWORK_CONGESTION_OR_QOS": "网络拥塞 / QoS限速",
        "PARTIAL_BLOCK_OR_DNS_TLS_ISSUE": "部分访问异常 / DNS或TLS问题",
        "REALITY_HANDSHAKE_ISSUE": "Reality握手异常",
        "REALITY_FAIL": "Reality连接失败",
        "EXIT_IP_MISMATCH": "出口IP异常",
        "EXIT_IP_UNKNOWN": "出口IP未知",
        "YOUTUBE_FAIL": "YouTube访问异常",
        "GOOGLE_FAIL": "Google连接失败",
        "DNS_FAIL": "DNS解析失败",
        "TCP_FAIL": "TCP连接失败",
        "REALITY_LATENCY_HIGH": "Reality延迟过高",
        "REALITY_LAT_UNKNOWN": "Reality延迟未知",
        "LATENCY_HIGH": "端口延迟过高",
        "LATENCY_UNKNOWN": "端口延迟未知",
        "FAIL2BAN_NOT_INSTALLED": "Fail2ban未安装",
    }

    for k, v in mapping.items():
        t = t.replace(k, v)

    return t

def _tg_poll_status_commands_v4(cfg, st):
    """
    Telegram status command polling via getUpdates.
    Reads token/chat_id from cfg['telegram']['bot_token'] and cfg['telegram']['chat_id'].
    Stores offset in st['_tg_update_offset'].
    Logs: [TG_STATUS] ...
    """
    try:
        import urllib.request, urllib.parse, json, time
        tg = (cfg or {}).get("telegram") or {}
        token = tg.get("bot_token")
        chat_id = tg.get("chat_id")
        if not token or not chat_id:
            log("[TG_STATUS] skip: missing telegram.bot_token or telegram.chat_id in config")
            return

        base = f"https://api.telegram.org/bot{token}"
        st["_tg_chat_id_for_status"] = str(chat_id)
        def call(method, params=None, timeout=8, retries=3):
            url = base + "/" + method
            if params:
                url += "?" + urllib.parse.urlencode(params)
            last_err = None
            for i in range(retries):
                try:
                    with urllib.request.urlopen(url, timeout=timeout) as r:
                        return r.read().decode("utf-8","ignore")
                except Exception as e:
                    last_err = e
                    log(f"[TG_STATUS] call {method} failed attempt={i+1}/{retries}: {e}")
                    try:
                        time.sleep(1)
                    except Exception:
                        pass
            raise last_err

        offset = int(st.get("_tg_update_offset") or 0)
        # short poll (no long-poll) to keep runtime predictable
        raw = call("getUpdates", {"timeout": 0, "limit": 10, "offset": offset})
        try:
            data = json.loads(raw)
        except Exception:
            log(f"[TG_STATUS] getUpdates JSON decode failed: {raw[:120]}")
            return

        if not data.get("ok"):
            log(f"[TG_STATUS] getUpdates not ok: {raw[:200]}")
            return

        updates = data.get("result") or []
        if not updates:
            _flush_status_outbox_v4(call, st)
            log(f"[TG_STATUS] no updates (offset={offset})")
            return

        # advance offset no matter what to avoid stuck
        max_id = max(u.get("update_id", 0) for u in updates)
        st["_tg_update_offset"] = max_id + 1
        st.setdefault("telegram", {})["_tg_update_offset"] = st["_tg_update_offset"]

        handled = 0
        for u in updates:
            msg = u.get("message") or u.get("edited_message") or {}
            txt = (msg.get("text") or "").strip().lower()
            cid = str((msg.get("chat") or {}).get("id") or "")
            if cid != str(chat_id):
                continue
            if txt not in ("net", "/net", "status", "/status"):
                continue

            # Build a simple status reply from current state snapshot
            last = st.get("last_diag") or {}

            # 统一使用同一份快照，避免端口/问题文本出现不同步
            pub_ip = last.get("pub_ip") or last.get("public_ip") or "?"
            expected = last.get("expected_exit_ip") or last.get("expected_ip") or "?"
            port_ms = last.get("port_ms", "?")
            rlat = last.get("reality_lat_ms", "?")
            google_ok = last.get("google_ok", None)
            youtube_ok = last.get("youtube_ok", None)
            issues = last.get("issues") or []

            # 如果 last_diag 不完整，再从最近日志整体回填一份统一快照
            if expected == "?" or pub_ip == "?" or port_ms == "?" or rlat == "?" or google_ok is None or youtube_ok is None or st.get('dns_ok', None) is None:
                try:
                    import re
                    log_path = str(Path.home() / "LAB/MONITOR_SYSTEM/monitor_system/logs/network_watch.log")
                    txt2 = Path(log_path).read_text(encoding="utf-8", errors="ignore")
                    for line in reversed(txt2.splitlines()[-300:]):
                        if "[DIAG] snapshot issues=" in line:
                            m = re.search(
                                r"issues=(\[[^\]]*\]).*?tcp_ok=(\S+)\s+reality_ok=(\S+)\s+google_ok=(\S+)\s+youtube_ok=(\S+)\s+pub_ip=(\S+)\s+expected_exit_ip=(\S+)\s+port_ms=(\S+)\s+reality_lat_ms=(\S+)",
                                line
                            )
                            if m:
                                issues_raw, tcp2, reality2, google2, youtube2, pub2, exp2, p2, r2 = m.groups()

                                def parse_bool(x):
                                    if x == "True":
                                        return True
                                    if x == "False":
                                        return False
                                    return None

                                pub_ip = pub2 or pub_ip
                                expected = exp2 or expected
                                port_ms = p2 or port_ms
                                rlat = r2 or rlat
                                google_ok = parse_bool(google2) if google_ok is None else google_ok
                                youtube_ok = parse_bool(youtube2) if youtube_ok is None else youtube_ok

                                dns_issue = ""
                                try:
                                    issues = eval(issues_raw, {"__builtins__": {}}, {})
                                except Exception:
                                    issues = [issues_raw]

                                if isinstance(issues, list):
                                    dns_google_fail = any(str(x).startswith("DNS_FAIL google.com") for x in issues)
                                    dns_youtube_fail = any(str(x).startswith("DNS_FAIL youtube.com") for x in issues)
                                    if dns_google_fail or dns_youtube_fail:
                                        st["dns_ok"] = False
                                    elif st.get("dns_ok", None) is None:
                                        st["dns_ok"] = True
                                elif st.get("dns_ok", None) is None:
                                    st["dns_ok"] = True
                                break
                except Exception:
                    pass

            def okfmt(v):
                if v is True: return "OK"
                if v is False: return "FAIL"
                return "?"

            openai_trace = last.get("openai_trace") or {}
            claude_trace = last.get("claude_trace") or {}
            openai_ok = last.get("openai_ok", None)
            claude_ok = last.get("claude_ok", None)

            vps_rtt_ms = last.get("vps_rtt_ms", "?")
            reality_rtt_ms = last.get("reality_rtt_ms", "?")
            gpt_rtt_ms = last.get("gpt_rtt_ms", "?")
            claude_rtt_ms = last.get("claude_rtt_ms", "?")

            # 保证回复内容一致：如果链路显示 FAIL，但 issues 为空，则补一个对应问题项
            if (not issues) and (openai_ok is False):
                issues = [f"OPENAI_LINK_FAIL loc={openai_trace.get('loc','?')} ip={openai_trace.get('ip','?')}"]
            elif (not issues) and (claude_ok is False):
                issues = [f"CLAUDE_LINK_FAIL loc={claude_trace.get('loc','?')} ip={claude_trace.get('ip','?')}"]

            if isinstance(issues, list) and issues:
                issues_text = "；".join([_issue_text_cn(x) for x in issues[:6]])
            else:
                issues_text = "无"

            vps_rtt_ms = last.get("vps_rtt_ms", "?")
            reality_rtt_ms = last.get("reality_rtt_ms", "?")
            gpt_rtt_ms = last.get("gpt_rtt_ms", "?")
            reality_ip = last.get("public_ip", "?")
            gpt_ip = openai_trace.get("ip", "?")
            claude_ip = claude_trace.get("ip", "?")
            gpt_loc = openai_trace.get("loc", "?")
            claude_loc = claude_trace.get("loc", "?")

            reply = (
                f"🌐 基准出口（Reality）\n"
                f"🌏 VPS出口: {reality_ip} (JP)\n\n"
                f"🌐 分流出口\n"
                f"🤖 GPT出口: {gpt_ip} ({gpt_loc})\n"
                f"🧠 Claude出口: {claude_ip} ({claude_loc})\n\n"
                f"📡 VPS RTT: {vps_rtt_ms}ms ({_rtt_status(vps_rtt_ms)})\n"
                f"🔐 Reality RTT: {reality_rtt_ms}ms ({_rtt_status(reality_rtt_ms)})\n"
                f"🤖 GPT RTT: {gpt_rtt_ms}ms ({_rtt_status(gpt_rtt_ms)})\n"
                f"🧠 Claude RTT: {claude_rtt_ms}ms ({_rtt_status(claude_rtt_ms)})\n\n"
                f"⚠ 状态: {issues_text}\n"
                f"@{time.strftime('%H:%M:%S')}"
            )

            # sendMessage
            try:
                send_raw = call("sendMessage", {"chat_id": chat_id, "text": reply}, timeout=10)
                send_ok = '"ok":true' in send_raw
                if not send_ok:
                    _queue_status_outbox(st, reply)
                    log(f"[TG_API_FAIL] replied status not ok (update_id={u.get('update_id')}): {send_raw[:160]}")
                else:
                    log(f"[TG_STATUS] replied status (update_id={u.get('update_id')}) sendMessage_ok=True")
            except Exception as e:
                _queue_status_outbox(st, reply)
                log(f"[TG_API_FAIL] replied status failed (update_id={u.get('update_id')}): {e}")
            handled += 1

        log(f"[TG_STATUS] processed {len(updates)} updates, handled={handled}, new_offset={st.get('_tg_update_offset')}")
    except Exception as e:
        try:
            log(f"[TG_STATUS] exception: {e}")
        except Exception:
            pass
# === TG_STATUS_V4_END ===


if __name__ == "__main__":
    try:
        main()
    except Exception as e:
        try:
            log(f"[FATAL_GUARD] {e}")
        except Exception:
            print("[FATAL_GUARD]", e)


