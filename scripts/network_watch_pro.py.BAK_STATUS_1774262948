# [AUTO_DISABLED] def check_tg_status(cfg):
    try:
        import urllib.request, json

        token = cfg.get("tg_bot_token")
        chat_id = str(cfg.get("tg_chat_id"))

        url = f"https://api.telegram.org/bot{token}/getUpdates"

        with urllib.request.urlopen(url, timeout=6) as r:
            data = json.loads(r.read().decode())

        for u in data.get("result", []):
            msg = u.get("message", {})
            text = (msg.get("text") or "").lower()
            cid = str((msg.get("chat") or {}).get("id"))

            if cid == chat_id and text in ("status","/status"):

                reply = "network_watch running OK"

                send=f"https://api.telegram.org/bot{token}/sendMessage?chat_id={chat_id}&text={reply}"

                urllib.request.urlopen(send, timeout=6)

    except:
        pass

