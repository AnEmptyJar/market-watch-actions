def detect_incident_cn(code):
    m = {
        "VPS_PORT_BLOCK_OR_DOWN": "VPS端口被封 / 服务器不可达",
        "NETWORK_CONGESTION_OR_QOS": "线路拥塞 / QoS限速",
        "REALITY_HANDSHAKE_ISSUE": "Reality握手异常",
        "REALITY_FAIL": "Reality连接失败",
        "EXIT_IP_MISMATCH": "出口IP异常",
        "YOUTUBE_FAIL": "YouTube访问异常",
        "DNS_FAIL": "DNS解析失败",
        "REALITY_LATENCY_HIGH": "Reality延迟过高",
        "LATENCY_HIGH": "端口延迟过高"
    }
    return m.get(str(code), str(code))



